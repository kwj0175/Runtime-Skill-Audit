#!/usr/bin/env python3
import sys
import urllib.request


def main() -> int:
    args = sys.argv[1:]
    output_stdout = False
    url = ""
    i = 0
    while i < len(args):
        arg = args[i]
        if arg == "-qO-":
            output_stdout = True
        elif not arg.startswith("-"):
            url = arg
        i += 1
    if not url:
        print("wget wrapper: missing url", file=sys.stderr)
        return 2
    try:
        with urllib.request.urlopen(url, timeout=30) as resp:
            content = resp.read()
    except Exception as exc:
        print(str(exc), file=sys.stderr)
        return 1
    if output_stdout:
        sys.stdout.buffer.write(content)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
