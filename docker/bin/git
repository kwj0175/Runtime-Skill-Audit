#!/usr/bin/env python3
import os
import subprocess
import sys


def main() -> int:
    args = sys.argv[1:]
    if not args:
        print("git wrapper: missing command", file=sys.stderr)
        return 2
    cmd = args[0]
    if cmd == "status":
        path = os.getcwd()
        try:
            entries = sorted(os.listdir(path))
        except Exception as exc:
            print(str(exc), file=sys.stderr)
            return 1
        for entry in entries:
            if entry.startswith(".git"):
                continue
            print(f"?? {entry}")
        return 0
    if cmd == "rev-parse" and "--show-toplevel" in args:
        print(os.getcwd())
        return 0
    if cmd in {"diff", "log", "branch", "remote"}:
        return 0
    print(f"git wrapper: unsupported command {' '.join(args)}", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
